# Public URL Twilio can reach (e.g. your ngrok tunnel) — used as the base for webhook callbacks
SERVER_BASE_URL=https://your-tunnel.ngrok.dev

# Server port
PORT=3001

# Twilio account credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret

# TwiML App SID — its Voice URL must point at {SERVER_BASE_URL}/voice/outgoing (POST)
TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (E.164) — used as callerId on outbound PSTN dials
TWILIO_CALLER_ID=+15551234567

# Twilio Auth Token — required for webhook signature validation AND for the
# Conversations REST client (server-side SMS send)
TWILIO_AUTH_TOKEN=

# Messaging Service SID — Conversations uses this to attach senders for SMS.
# Console → Messaging → Services. Integration tab must be set to
# "Send a webhook" with URL {SERVER_BASE_URL}/webhooks/messaging/inbound;
# that endpoint bridges inbound SMS into a Conversation so onMessageAdded
# remains the single source of truth for both inbound and outbound.
MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

CONVERSATION_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Twilio edge region for AccessToken (e.g. au1, ie1, sg1)
TWILIO_REGION=

# destinationType=assistant — AI Assistant SID for <Connect><Assistant>
VOICE_SDK_ASSISTANT_SID=
# destinationType=flex — TaskRouter workflow + workspace for <Enqueue>
FLEX_WORKFLOW_SID=
FLEX_WORKSPACE_SID=
